VITE_NAVER_CLIENT_SECRET=
# CloudFront 도메인 또는 S3 버킷 URL
VITE_IMG_SERVER=https://your-cloudfront-domain.cloudfront.net
VITE_TMAP_APP_KEY=
VITE_ODSAY_API_KEY=
