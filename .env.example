# ===== AWS RDS (MySQL) =====
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_NAME=matgotdb
DB_USERNAME=admin
DB_PASSWORD=

# ===== JWT =====
JWT_SECRET=
JWT_EXPIRATION=86400000

# ===== Gmail SMTP =====
MAIL_USERNAME=
MAIL_PASSWORD=

# ===== Google OAuth2 =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ===== Naver (kgy) =====
NAVER_CLIENT_ID_K=
NAVER_CLIENT_SECRET_K=

# ===== Naver API =====
NAVER_CLIENT_ID=
NAVER_SECRET=

# ===== Clova OCR =====
CLOVA_OCR_SECRET_KEY=
CLOVA_OCR_API_URL=

# ===== AWS S3 =====
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
S3_BUCKET=

# ===== Frontend (Vite build args) =====
VITE_BACKSERVER=http://your-ec2-public-ip:9999
VITE_NAVER_MAP_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_KAKAO_JAVASCRIPT_KEY=
VITE_KAKAO_REST_API_KEY=
VITE_KAKAO_REDIRECT_URI=
VITE_KAKAO_CLIENT_SECRET=
